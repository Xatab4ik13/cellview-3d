# Server
PORT=3001
NODE_ENV=production

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=kladovka78
DB_PASSWORD=your_secure_password_here
DB_NAME=kladovka78

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=https://kladovka78.ru

# SMTP (Timeweb)
SMTP_HOST=smtp.timeweb.ru
SMTP_PORT=465
SMTP_USER=info@kladovka78.ru
SMTP_PASS=your_smtp_password_here

# File uploads
UPLOAD_DIR=/var/www/kladovka78/uploads
MAX_FILE_SIZE=10485760

# VTB Merchant API (sandbox по умолчанию)
VTB_CLIENT_ID=your_client_id_here
VTB_CLIENT_SECRET=your_client_secret_here
VTB_MERCHANT_AUTHORIZATION=your_merchant_authorization_here
VTB_OAUTH_URL=https://epa-ift-sbp.vtb.ru:443/passport/oauth2/token
VTB_API_URL=https://test3.api.vtb.ru:8443/openapi/smb/efcp/e-commerce/v1
VTB_ORDER_EXPIRE_MINUTES=120
